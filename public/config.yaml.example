# ============================================
# 竞品情报简报 — 配置示例（公开版）
# 复制此文件为 config.yaml 并填入你的信息
# ============================================

project_name: "AI Agent 竞品情报简报"

# ========== 竞品与关键词 ==========
competitors:
  - name: "Dify"
    keywords:
      - "Dify AI platform new release"
      - "Dify workflow update"
      - "Dify 更新"
    freshness: "week"
    max_results: 5

  - name: "Coze / 扣子"
    keywords:
      - "Coze AI agent platform update"
      - "扣子 平台更新"
    freshness: "week"
    max_results: 5

  - name: "LangChain / LangGraph"
    keywords:
      - "LangChain update"
      - "LangGraph release"
    freshness: "week"
    max_results: 5

  - name: "CrewAI"
    keywords:
      - "CrewAI multi-agent update"
    freshness: "week"
    max_results: 3

  - name: "OpenAI Agents SDK"
    keywords:
      - "OpenAI Agents SDK update"
    freshness: "week"
    max_results: 3

# ========== 附加搜索话题 ==========
topics:
  - "AI agent 行业趋势"
  - "AI agent open source"
  freshness: "week"
  max_results: 3

# ========== 推送配置 ==========
delivery:
  feishu:
    enabled: true
    target_chat: ""             # 留空=私聊，填写 chat_id 为群聊
    target_type: "p2p"          # p2p = 私聊 | chat = 群聊
    user_open_id: "ou_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"  # 替换为你的 open_id
